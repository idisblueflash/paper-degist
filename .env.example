# Secrets / API keys template — copy to `.env` and fill in the values.
#   cp .env.example .env      # then edit .env (it is gitignored, never committed)
#
# These are read from the process environment (the steps use Typer `envvar=`
# options / os.environ), so load `.env` into your shell before running a step:
#   set -a; source .env; set +a
#   uv run discover "…" --source serpapi
# (or pass the key inline with the step's flag, e.g. --s2-api-key).

# SerpAPI key — Google Scholar / web search source for `discover`.
# Get one at https://serpapi.com/manage-api-key
SERPAPI_API_KEY=

# Semantic Scholar API key (optional) — raises the `discover --source s2` rate
# limit; without it S2's free tier is heavily 429-rate-limited.
S2_API_KEY=

# Contact email Unpaywall requires for `resolve-oa` (US9/US10).
UNPAYWALL_EMAIL=
